    {
      "goalId": "WR-G2",
      "departmentId": "water-resources",
      "department": "Water Resources Department",
      "goalText": "Reduce electricity demand by 40% by 2025 from 2007.",
      "targetYear": 2025,
      "targetPassedUnverified": true,
      "fundingState": "funded",
      "deprioritized": false,
      "years": [
        {
          "year": 2023,
          "reportingState": "reported",
          "implementationStatus": "Ongoing",
          "progressDirection": "unknown",
          "statusText": "The Water Resources Department prepared an engineering study of its water and wastewater equipment (completed 2021); replacement of equipment is now prioritized based on the study's energy efficiency measurements.",
          "citation": {
            "source": "progress2023",
            "page": 16
          },
          "evidenceType": "city_report"
        },
        {
          "year": 2024,
          "reportingState": "reported",
          "implementationStatus": "Ongoing",
          "progressDirection": "unknown",
          "statusText": "The Water Resources Department finalized its Electrical System Evaluation and Preliminary Engineering Report, replaced three motor control centers, and added a new power feeder from the main substation at the T.Z. Osborne Wastewater Reclamation Facility. Two outdated emergency generators are being replaced.",
          "citation": {
            "source": "progress2024",
            "page": 17
          },
          "evidenceType": "city_report"
        },
        {
          "year": 2025,
          "reportingState": "reported",
          "implementationStatus": "unknown",
          "progressDirection": "unknown",
          "statusText": "Preliminary figures put electricity use by the Water Resources Department at 69,845 MWh in 2025, a 2.0% increase since 2019. In May, the department introduced the GSO WaterWise Portal, supported by the City's system-wide upgrade to smart meters, offering customized usage alerts, near real-time water use data, and personalized conservation tips.",
          "citation": {
            "source": "progress2025",
            "page": 12
          },
          "evidenceType": "city_report"
        }
      ],
