    {
      "goalId": "TR-E-G1",
      "departmentId": "transportation-electricity",
      "department": "Transportation Department (Electricity)",
      "goalText": "Increase LED streetlamp conversion by 5% per year.",
      "targetYear": null,
      "targetPassedUnverified": false,
      "fundingState": "no_linked_funding",
      "deprioritized": false,
      "years": [
        {
          "year": 2023,
          "reportingState": "reported",
          "implementationStatus": "Ongoing",
          "progressDirection": "unknown",
          "statusText": "As of October 2023, 39.6% of all lamps used LEDs, up from 15.2% in 2019 (avg. pace 6.1%/year).",
          "citation": {
            "source": "progress2023",
            "page": 16
          },
          "evidenceType": "city_report"
        },
        {
          "year": 2024,
          "reportingState": "reported",
          "implementationStatus": "Ongoing",
          "progressDirection": "unknown",
          "statusText": "As of December 2024, 41.2% converted, up from 15.2% in 2019 (avg. pace 5.2%/year).",
          "citation": {
            "source": "progress2024",
            "page": 17
          },
          "evidenceType": "city_report"
        },
        {
          "year": 2025,
          "reportingState": "reported",
          "implementationStatus": "Ongoing",
          "progressDirection": "unknown",
          "statusText": "GDOT works with Duke Energy to coordinate LED conversion of the company's more than 27,400 streetlamps and other public outdoor lighting units. LED streetlamp conversion data for 2025 (percent converted) was not available for inclusion in this report. However, total energy consumption by streetlamps dropped from 18,276 MWh in 2022 to 1,952 MWh in 2025 — a reduction of 89.3%.",
          "citation": {
            "source": "progress2025",
            "page": 12
          },
          "evidenceType": "city_report"
        }
      ],
