    {
      "goalId": "EI-G1",
      "departmentId": "buildings-ei",
      "department": "Buildings Managed by Engineering & Inspections",
      "goalText": "Reduce electricity demand by 40% by 2025 from 2007.",
      "targetYear": 2025,
      "targetPassedUnverified": true,
      "fundingState": "funded",
      "deprioritized": false,
      "years": [
        {
          "year": 2023,
          "reportingState": "reported",
          "implementationStatus": "Initiated",
          "progressDirection": "unknown",
          "statusText": "The OSR developed an RFP for contractors to provide energy audits and recommendations for energy conservation measures in the City's largest energy-consuming buildings, in compliance with ASHRAE standards, including MWBE Office participation.",
          "citation": {
            "source": "progress2023",
            "page": 17
          },
          "evidenceType": "city_report"
        },
        {
          "year": 2024,
          "reportingState": "reported",
          "implementationStatus": "In Progress",
          "progressDirection": "unknown",
          "statusText": "The OSR contracted with a vendor to provide energy audits in select City buildings. Ten buildings were studied in 2024, with more planned for 2025.",
          "citation": {
            "source": "progress2024",
            "page": 18
          },
          "evidenceType": "city_report"
        },
        {
          "year": 2025,
          "reportingState": "reported",
          "implementationStatus": "In Progress",
          "progressDirection": "unknown",
          "statusText": "Preliminary figures put total electricity use in the City's buildings at 45,576 MWh in 2025, a 1.0% increase since 2019. OSR contracted with Systems Contractors, Inc. (SCI) to audit the City's 10-highest energy-using buildings and recommend energy conservation measures. Level 1 audits identified needed maintenance and corrective measures; SCI suggested more-detailed Level 2 audits. OSR is working to carry out these projects and identify needed funding. In October, OSR encouraged staff to coordinate major energy-consuming activities with Duke Energy's non-summer, seasonal time-of-use electricity rates.",
          "citation": {
            "source": "progress2025",
            "page": 13
          },
          "evidenceType": "city_report"
        }
      ],
      "transitions": [
